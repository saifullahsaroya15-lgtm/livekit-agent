LIVEKIT_PUBLIC_HOST=livekit.example.com

# LiveKit API credentials (must match what your agent uses)
LIVEKIT_API_KEY=your_api_key_here
# Must be >= 32 characters (LiveKit enforces this)
LIVEKIT_API_SECRET=your_api_secret_here_at_least_32_chars_long

# LiveKit RTC public IP advertisement settings
# - Leave USE_EXTERNAL_IP=true for typical EC2/public hosts
# - If discovery is wrong (NAT/Gateway), set NODE_IP to the actual public IP
LIVEKIT_RTC_USE_EXTERNAL_IP=true
# LIVEKIT_RTC_NODE_IP=203.0.113.10

# Optional: pin images for repeatable production deployments
# LIVEKIT_SERVER_IMAGE=livekit/livekit-server:v1.9.11
# LIVEKIT_SIP_IMAGE=livekit/sip:latest

# Email used by Caddy for Let's Encrypt certificates
ACME_EMAIL=you@example.com

