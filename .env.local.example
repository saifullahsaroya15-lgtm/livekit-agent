LIVEKIT_PUBLIC_HOST=localhost

# LiveKit API credentials (must match what your agent uses when you later test end-to-end)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_devsecret_devsecret_devsecret

# Local-only: Caddy isn't used, so email is ignored
ACME_EMAIL=local@example.com

# LiveKit RTC public IP advertisement settings
LIVEKIT_RTC_USE_EXTERNAL_IP=false
# LIVEKIT_RTC_NODE_IP=

